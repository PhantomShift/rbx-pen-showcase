-- Note - Specifically for grabbing relevant uinput header values
-- Should not be used as a reference for C# codegen

local fs = require("@lune/fs")
local process = require("@lune/process")

local LINUX_HEADERS = "/usr/include/linux"
local GCC = "gcc"

local TEMP_C_SRC = "PEN_PRESSURE_MACRO_EXPAND.c"
local F_OUT = "plugin/linux/LinuxIoctlGenerated.cs"

local TMP_C_TEMPLATE = [[
#include <linux/uinput.h>
]]

local OUT_TEMPLATE = [[

// This file has been automatically generated by gen_head.lua

using System;
using System.Runtime.InteropServices;

namespace pressure_mapper.Linux;

public static partial class %s
{
#pragma warning disable IDE0047
%s
#pragma warning restore IDE0047
}

]]

local STRUCT_SIZES = {
    -- u16 + 6 * s32
    uinput_abs_setup = 2 + 6 * 4,
    -- u32 + s32 + 2 * (u16 + s16 + u16 + 4 * u16)
    uinput_ff_upload = 4 + 4 + 2 * (2 + 2 + 2 + 4 * 2),
    -- u32 + s32 + u32
    uinput_ff_erase = 4 + 4 + 4,
    -- 4 * u16 + 80 * char + u32
    uinput_setup = 4 * 2 + 80 + 4;
}

local function getOption(long: string, alias: string) : string?
    for i = 1, #process.args - 1 do
        if process.args[i] == `--{long}` or process.args[i] == `-{alias}` and process.args[i+1]:match("^[^-]") then
            return process.args[i+1]
        end
    end

    return nil
end

local headers_dir = getOption("override-headers-dir", "o") or LINUX_HEADERS
local gcc = getOption("gcc", "gcc") or GCC

local uinput = `{headers_dir}/uinput.h`

local uinput_contents = fs.readFile(uinput)

local names = {}
local defines = {}
for name, val in uinput_contents:gmatch("#define%s+([%w_]+)%s(%x*x?%x+)") do
    defines[name] =  {
        type = "uint",
        value = tonumber(val)
    }
    
    table.insert(names, name)
end

local to_expand = {}

for name, _val in uinput_contents:gmatch("#define%s+([%w_]+)%s+(_%w+%b())") do
    table.insert(to_expand, name)
end

if #to_expand > 0 then
    table.sort(to_expand)
    local src = TMP_C_TEMPLATE
    for _, name in to_expand do
        src ..= `\nconst int expand__{name} = {name};`
    end

    fs.writeFile(TEMP_C_SRC, src)

    -- local result = process.exec(gcc, {"-dm", "-E", TEMP_C_SRC})
    local result = process.exec(gcc, {"-E", TEMP_C_SRC})

    if not result.ok then
        print(`gcc failed to run. stderr: {result.stderr}`)
        process.exit(1)
    end

    fs.removeFile(TEMP_C_SRC)

    for name, matched in result.stdout:gmatch("const int expand__([%w_]+) =.-(%(.-);") do
        local macro = matched:gsub("%s*#.+$", "")
        local replaced = macro:gsub("sizeof%(struct%s+([%w_]+)%)", function(struct_name)
            return STRUCT_SIZES[struct_name] or `UNKNOWN_{struct_name}`
        end):gsub("unsigned int", "uint"):gsub("'(%w)'", function(char)
            return `(byte)'{char}'`
        end):gsub("sizeof%([%w_]+%s*%*%)", "8")
        -- print(name, replaced)
        defines[name] = {
            type = "uint",
            value = replaced,
        }
        table.insert(names, name)
    end
end

table.sort(names)

local output = ""
for _, name in ipairs(names) do
    output ..= `\n    public const {defines[name].type} {name} = {defines[name].value};`
    -- output ..= `\n    public readonly static {defines[name].type} {name} = {defines[name].value};`
end

fs.writeFile(F_OUT, OUT_TEMPLATE:format("UinputConst", output))

-- InputEventCodes

local IEC_OUT = "plugin/linux/InputEventCodesGenerated.cs"
local iec_h = `{headers_dir}/input-event-codes.h`
local iec_contents = fs.readFile(iec_h)

local iec_out = ""
for name, expr in iec_contents:gmatch("#define%s+(%w[%w_]*)%s+(.-)[\n/]") do
    iec_out ..= `\n    public const int {name} = {expr};`
end

fs.writeFile(IEC_OUT, OUT_TEMPLATE:format("InputEventCodes", iec_out))
